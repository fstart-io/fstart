// Board definition for QEMU AArch64 virt machine.
//
// Memory map from QEMU hw/arm/virt.c (confirmed via coreboot):
//   Flash:  0x0000_0000 .. 0x0800_0000 (128 MiB, two 64 MiB banks)
//   UART:   0x0900_0000 (PL011, 4 KiB)
//   RAM:    0x4000_0000 onwards

(
    name: "qemu-aarch64",
    platform: "aarch64",

    // Memory regions: only ROM and RAM.
    // Device MMIO addresses are in the device resources, not here.
    // flash_base = XIP flash base for AArch64 virt.
    // flash_size = 128 MiB flash.
    memory: (
        regions: [
            ( name: "flash", base: 0x00000000, size: 0x08000000, kind: Rom ),
            ( name: "ram",   base: 0x40000000, size: 0x08000000, kind: Ram ),
        ],
        flash_base: Some(0x00000000),
        flash_size: Some(0x08000000),
    ),

    devices: [
        (
            name: "uart0",
            compatible: "arm,pl011",
            driver: "pl011",
            services: ["Console"],
            resources: (
                mmio_base: Some(0x09000000),
                io_base: None,
                size: Some(0x1000),
                // QEMU virt PL011 ignores baud rate, but we match coreboot's
                // default refclk of 115200 * 16 = 1843200 Hz.
                clock_freq: Some(1843200),
                baud_rate: Some(115200),
                irq: Some(33),
                bus_addr: None,
                bus_speed: None,
            ),
        ),
    ],

    stages: Monolithic((
        capabilities: [
            ConsoleInit( device: "uart0" ),
            MemoryInit,
            BootMedia(MemoryMapped( base: 0x00000000, size: 0x08000000 )),
            SigVerify,
            FdtPrepare,
            PayloadLoad,
        ],
        load_addr: 0x00000000,
        stack_size: 0x40000,
        // Place data/BSS/stack at 2 MiB into RAM to avoid QEMU's DTB.
        // QEMU places the FDT at RAM base (0x40000000) on firmware boot;
        // without this, BSS clearing in _start would destroy the DTB.
        data_addr: Some(0x40200000),
    )),

    security: (
        signing_algorithm: Ed25519,
        pubkey_file: "keys/dev-signing.pub",
        required_digests: [Sha256, Sha3_256],
    ),

    mode: Rigid,

    // Linux boot via ARM Trusted Firmware BL31.
    //
    // Memory layout:
    //   0x00000000 - Flash (fstart firmware, XIP from ROM)
    //   0x0E090000 - ATF BL31 (loaded from FFS into secure SRAM)
    //   0x40000000 - RAM start; QEMU places DTB here (read-only, ~64 KiB)
    //   0x40200000 - BSS + stack (data_addr, 2 MiB past RAM base)
    //   0x40100000 - Patched DTB (copied from QEMU-provided DTB at 0x40000000)
    //   0x41000000 - Linux kernel (loaded from FFS)
    //   0x48000000 - End of RAM (128 MiB)
    //
    // BL31 is linked at 0x0E090000 (QEMU virt secure SRAM region) — this
    // matches coreboot's layout. BL31 initialises at EL3, then erets to
    // Linux (BL33) at EL2 with x0 = DTB pointer.
    payload: Some((
        kind: LinuxBoot,
        kernel_file: Some("Image"),
        kernel_load_addr: Some(0x41000000),
        fdt: Platform,
        dtb_addr: Some(0x40100000),
        // QEMU AArch64 virt places the DTB at the base of RAM (0x40000000)
        // on firmware boot (-bios). Unlike RISC-V where a1=DTB, AArch64
        // firmware boot zeroes all registers — x0 is always 0, not a DTB
        // pointer. We tell codegen the known DTB location explicitly.
        src_dtb_addr: Some(0x40000000),
        bootargs: Some("console=ttyAMA0 earlycon=pl011,0x09000000"),
        firmware: Some((
            kind: ArmTrustedFirmware,
            file: "bl31.bin",
            load_addr: 0x0E090000,
        )),
    )),
)
