// Board definition for QEMU AArch64 virt machine (Flexible mode).
//
// Identical to qemu-aarch64 but uses Flexible build mode to exercise
// enum dispatch codegen. In flexible mode, service enum wrappers are
// generated for runtime driver selection via match dispatch.
//
// Memory map from QEMU hw/arm/virt.c:
//   Flash:  0x0000_0000 .. 0x0800_0000 (128 MiB, two 64 MiB banks)
//   UART:   0x0900_0000 (PL011, 4 KiB)
//   RAM:    0x4000_0000 onwards
//
// Boot flow: CPU resets at RVBAR (0x0), executing directly from flash.
// Firmware runs XIP from flash; writable data goes to RAM.

(
    name: "qemu-aarch64-flex",
    platform: Aarch64,

    // Memory regions: ROM (flash) and RAM.
    // Device MMIO addresses are in the driver config, not here.
    memory: (
        regions: [
            ( name: "flash", base: 0x00000000, size: 0x08000000, kind: Rom ),
            ( name: "ram",   base: 0x40000000, size: 0x08000000, kind: Ram ),
        ],
        flash_base: Some(0x00000000),
        flash_size: Some(0x08000000),
    ),

    devices: [
        (
            name: "uart0",
            driver: Pl011((
                base_addr: 0x09000000,
                clock_freq: 1843200,
                baud_rate: 115200,
            )),
            services: ["Console"],
        ),
    ],

    stages: Monolithic((
        capabilities: [
            ConsoleInit( device: "uart0" ),
        ],
        load_addr: 0x00000000,
        stack_size: 0x10000,
        // Place data/BSS/stack at 2 MiB into RAM to avoid QEMU's DTB.
        // QEMU places the FDT at RAM base (0x40000000) on firmware boot.
        data_addr: Some(0x40200000),
    )),

    security: (
        signing_algorithm: Ed25519,
        pubkey_file: "keys/dev-signing.pub",
        required_digests: [Sha256, Sha3_256],
    ),

    mode: Flexible,

    payload: None,
)
