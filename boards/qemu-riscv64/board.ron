// Board definition for QEMU RISC-V 64 virt machine.
//
// Memory map from QEMU hw/riscv/virt.c:
//   MROM:   0x0000_1000 .. 0x0000_FFFF (reset trampoline, jumps to flash)
//   Flash:  0x2000_0000 .. 0x2400_0000 (64 MiB, two 32 MiB banks)
//   UART:   0x1000_0000 (NS16550A, 256 B)
//   RAM:    0x8000_0000 onwards
//
// Boot flow: CPU resets to MROM (0x1000), which sets a0=hartid,
// a1=DTB addr, then jumps to flash base (0x20000000).  Firmware
// executes in place (XIP) from flash; writable data goes to RAM.

(
    name: "qemu-riscv64",
    platform: "riscv64",

    // Memory regions: ROM (flash bank 0) and RAM.
    // Device MMIO addresses are in the device resources, not here.
    // flash_base/flash_size describe flash bank 0 where the FFS image
    // or monolithic firmware is placed via QEMU pflash.
    memory: (
        regions: [
            ( name: "flash", base: 0x20000000, size: 0x02000000, kind: Rom ),
            ( name: "ram",   base: 0x80000000, size: 0x08000000, kind: Ram ),
        ],
        flash_base: Some(0x20000000),
        flash_size: Some(0x02000000),
    ),

    devices: [
        (
            name: "uart0",
            compatible: "ns16550a",
            driver: "ns16550",
            services: ["Console"],
            resources: (
                mmio_base: Some(0x10000000),
                io_base: None,
                size: Some(0x100),
                clock_freq: Some(3686400),
                baud_rate: Some(115200),
                irq: Some(10),
                bus_addr: None,
                bus_speed: None,
            ),
        ),
    ],

    stages: Monolithic((
        capabilities: [
            ConsoleInit( device: "uart0" ),
            MemoryInit,
            SigVerify,
            FdtPrepare,
            PayloadLoad,
        ],
        load_addr: 0x20000000,
        // 256 KiB — debug builds with Ed25519 + SHA-256/SHA3 use
        // significant stack space. 64 KiB overflows in debug mode.
        stack_size: 0x40000,
    )),

    security: (
        signing_algorithm: Ed25519,
        pubkey_file: "keys/dev-signing.pub",
        required_digests: [Sha256, Sha3_256],
    ),

    mode: Rigid,

    // Linux boot via RustSBI fw_dynamic protocol.
    //
    // Memory layout:
    //   0x20000000 - Flash bank 0 (firmware code, XIP from ROM)
    //   0x80000000 - RAM start; BSS + stack (XIP writable data)
    //   0x80100000 - RustSBI fw_dynamic (loaded from FFS into RAM)
    //   0x82000000 - Linux kernel (loaded from FFS into RAM)
    //   0x87F00000 - Patched DTB (copied from QEMU-provided DTB)
    //   0x88000000 - End of RAM
    //
    // QEMU places its DTB near the top of DRAM (~0x87E00000) and passes
    // the address via a1; no data_addr offset is needed (unlike AArch64
    // where QEMU puts the DTB at RAM base).
    payload: Some((
        kind: LinuxBoot,
        kernel_file: Some("vmlinux"),
        kernel_load_addr: Some(0x82000000),
        fdt: Platform,
        dtb_addr: Some(0x87F00000),
        bootargs: Some("console=ttyS0 earlycon=sbi"),
        firmware: Some((
            kind: OpenSbi,
            file: "fw_dynamic.bin",
            load_addr: 0x80100000,
        )),
    )),
)
