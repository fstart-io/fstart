// Board definition for QEMU RISC-V 64 virt machine.
//
// This RON file is the single source of truth for this board.
// The build system reads it and generates:
// - Stage entry point (fstart_main) with capability call sequence
// - Static driver instantiation
// - Linker script from memory map
// - (future) FDT for OS handoff

(
    name: "qemu-riscv64",
    platform: "riscv64",

    // Memory regions: only ROM and RAM.
    // Device MMIO addresses are in the device resources, not here.
    // flash_base = where QEMU loads the FFS image via -device loader.
    // flash_size = 16 MiB reservation for the FFS image. BSS and stack
    // are placed at flash_base + flash_size (0x81000000) by the linker
    // script, so all payload load addresses must be beyond that region.
    memory: (
        regions: [
            ( name: "ram", base: 0x80000000, size: 0x08000000, kind: Ram ),
        ],
        flash_base: Some(0x80000000),
        flash_size: Some(0x01000000),
    ),

    devices: [
        (
            name: "uart0",
            compatible: "ns16550a",
            driver: "ns16550",
            services: ["Console"],
            resources: (
                mmio_base: Some(0x10000000),
                io_base: None,
                size: Some(0x100),
                clock_freq: Some(3686400),
                baud_rate: Some(115200),
                irq: Some(10),
                bus_addr: None,
                bus_speed: None,
            ),
        ),
    ],

    stages: Monolithic((
        capabilities: [
            ConsoleInit( device: "uart0" ),
            MemoryInit,
            SigVerify,
            FdtPrepare,
            PayloadLoad,
        ],
        load_addr: 0x80000000,
        // 256 KiB — debug builds with Ed25519 + SHA-256/SHA3 use
        // significant stack space. 64 KiB overflows in debug mode.
        stack_size: 0x40000,
    )),

    security: (
        signing_algorithm: Ed25519,
        pubkey_file: "keys/dev-signing.pub",
        required_digests: [Sha256, Sha3_256],
    ),

    mode: Rigid,

    // Linux boot via RustSBI fw_dynamic protocol.
    //
    // Memory layout (128 MiB RAM at 0x80000000):
    //   0x80000000 - FFS image (16 MiB reservation, ~9 MiB actual)
    //   0x80100000 - RustSBI fw_dynamic (loaded from FFS, within reservation)
    //   0x81000000 - BSS + stack (placed by linker at flash_base + flash_size)
    //   0x82000000 - Linux kernel (loaded from FFS, in free RAM)
    //   0x87F00000 - Patched DTB (copied from QEMU-provided DTB)
    //   0x88000000 - End of RAM
    //
    // kernel_load_addr must be beyond the firmware infrastructure (BSS/stack
    // at 0x81000000+). A 7.98 MiB kernel at 0x82000000 ends at ~0x827A0000,
    // well below the DTB at 0x87F00000.
    payload: Some((
        kind: LinuxBoot,
        kernel_file: Some("vmlinux"),
        kernel_load_addr: Some(0x82000000),
        fdt: Platform,
        dtb_addr: Some(0x87F00000),
        bootargs: Some("console=ttyS0 earlycon=sbi"),
        firmware: Some((
            kind: OpenSbi,
            file: "fw_dynamic.bin",
            load_addr: 0x80100000,
        )),
    )),
)
