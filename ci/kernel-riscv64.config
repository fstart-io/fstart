# RISC-V 64 kernel config fragment for QEMU virt + SiFive machines.
#
# Applied on top of tinyconfig:
#   make ARCH=riscv tinyconfig
#   cat ci/kernel-riscv64.config >> .config
#   make ARCH=riscv CROSS_COMPILE=riscv64-linux-gnu- olddefconfig
#   make ARCH=riscv CROSS_COMPILE=riscv64-linux-gnu- -j$(nproc)

# Architecture — RV64GC (IMAFD + C)
CONFIG_64BIT=y
CONFIG_ARCH_RV64I=y
CONFIG_CMODEL_MEDANY=y
CONFIG_RISCV_ISA_C=y

# FPU — save/restore F+D registers on context switch
CONFIG_FPU=y

# SBI interface (earlycon, timer, IPI, shutdown)
CONFIG_RISCV_SBI=y
CONFIG_RISCV_SBI_V01=y

# SMP
CONFIG_SMP=y
CONFIG_NR_CPUS=8

# Console / TTY
CONFIG_TTY=y
CONFIG_PRINTK=y
CONFIG_SERIAL_EARLYCON=y

# NS16550 UART (QEMU virt)
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_OF_PLATFORM=y

# SBI console (earlycon=sbi)
CONFIG_SERIAL_EARLYCON_RISCV_SBI=y
CONFIG_HVC_RISCV_SBI=y

# SiFive UART (QEMU sifive_u machine)
CONFIG_SERIAL_SIFIVE=y
CONFIG_SERIAL_SIFIVE_CONSOLE=y

# Initramfs support
CONFIG_BLK_DEV_INITRD=y

# Binary / runtime support
CONFIG_BINFMT_ELF=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y

# Filesystems
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y

# Device tree
CONFIG_OF=y
CONFIG_OF_EARLY_FLATTREE=y

# Timer
CONFIG_RISCV_TIMER=y
CONFIG_HZ_100=y

# Memory management
CONFIG_MMU=y

# VirtIO (QEMU)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_CONSOLE=y

# Block device layer
CONFIG_BLOCK=y
