# ARMv7 kernel config fragment for QEMU virt machine.
#
# Applied on top of tinyconfig:
#   make ARCH=arm tinyconfig
#   cat ci/kernel-armv7.config >> .config
#   make ARCH=arm CROSS_COMPILE=arm-linux-gnueabihf- olddefconfig
#   make ARCH=arm CROSS_COMPILE=arm-linux-gnueabihf- -j$(nproc)

# Architecture — QEMU virt machine (Cortex-A15)
CONFIG_ARCH_MULTIPLATFORM=y
CONFIG_ARCH_MULTI_V7=y
CONFIG_ARCH_VIRT=y

# FPU / NEON
CONFIG_VFP=y
CONFIG_NEON=y
CONFIG_KERNEL_MODE_NEON=y

# SMP
CONFIG_SMP=y
CONFIG_NR_CPUS=4

# Console / TTY
CONFIG_TTY=y
CONFIG_PRINTK=y
CONFIG_SERIAL_EARLYCON=y

# PL011 UART (QEMU virt)
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# Initramfs support
CONFIG_BLK_DEV_INITRD=y

# Binary / runtime support
CONFIG_BINFMT_ELF=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y

# Filesystems
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y

# Device tree
CONFIG_USE_OF=y

# Timer
CONFIG_ARM_ARCH_TIMER=y
CONFIG_HZ_100=y

# Memory management
CONFIG_MMU=y
CONFIG_HIGHMEM=y

# Interrupt controller
CONFIG_ARM_GIC=y
CONFIG_ARM_GIC_V3=y

# VirtIO (QEMU)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_CONSOLE=y

# Block device layer
CONFIG_BLOCK=y

# Compressed kernel (zImage)
CONFIG_KERNEL_GZIP=y
