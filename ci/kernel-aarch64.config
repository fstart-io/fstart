# AArch64 kernel config fragment for QEMU virt machine.
#
# Applied on top of tinyconfig:
#   make ARCH=arm64 tinyconfig
#   cat ci/kernel-aarch64.config >> .config
#   make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- olddefconfig
#   make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- -j$(nproc)
#
# FPU (NEON/VFP) is mandatory on ARMv8-A — always enabled.

# Architecture
CONFIG_64BIT=y
CONFIG_ARM64=y

# SMP
CONFIG_SMP=y
CONFIG_NR_CPUS=8

# Console / TTY
CONFIG_TTY=y
CONFIG_PRINTK=y
CONFIG_SERIAL_EARLYCON=y

# PL011 UART (QEMU virt)
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# Initramfs support
CONFIG_BLK_DEV_INITRD=y

# Binary / runtime support
CONFIG_BINFMT_ELF=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_COMPAT=y

# Filesystems
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y

# Device tree
CONFIG_OF=y
CONFIG_OF_EARLY_FLATTREE=y

# Timer
CONFIG_ARM_ARCH_TIMER=y
CONFIG_HZ_100=y

# Memory management
CONFIG_MMU=y

# Interrupt controller (GICv3, used by QEMU virt with gic-version=3)
CONFIG_ARM_GIC=y
CONFIG_ARM_GIC_V3=y

# PCI (QEMU virt exposes devices on PCI)
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y

# VirtIO (QEMU)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_CONSOLE=y

# Block device layer
CONFIG_BLOCK=y
